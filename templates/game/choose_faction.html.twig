{% extends 'base.html.twig' %}
{% block title %}Choix de faction{% endblock %}
{% block body %}
    <script>
        window.existingPlayers = {{ existingPlayers|json_encode|raw }};
    </script>
    <div id="form" class="form-background">
        <div class="form">
            <div class="form-content">
                <div class="mix">
                    <div class="headline">
                        <h3 class="text-headline" id="form-title">Choisissez une faction et rejoignez une partie existante</h3>
                    </div>
                </div>
                {{ form_start(form, { attr: { class: 'all-form-game' } }) }}

                    {# Section games #}
                    <div class="games-section">
                        <div class="games-grid" id="games-grid">
                            {% for game_field in form.game %}
                                <div class="game-card" data-game-label="{{ game_field.vars.label }}">
                                    <label class="game-label">
                                        {{ form_widget(game_field) }}
                                        <div class="game-content">
                                            <h4 class="game-name">{{ game_field.vars.label }}</h4>
                                            <p class="game-description">{{ game_field.vars.attr['data-description'] }}</p>
                                        </div>
                                    </label>
                                </div>
                            {% endfor %}
                        </div>

                        {# Résumé compact affiché après sélection #}
                        <div class="game-selected-summary" id="game-selected-summary" style="display:none;">
                            <h4 class="game-selected-label" id="game-selected-label"></h4>
                            <button type="button" class="btn-change-game" id="btn-change-game">Changer</button>
                        </div>
                    </div>

                    {# Section factions #}
                    <div class="factions-section" id="factions-section" style="display:none;">
                        <h4>Sélectionnez votre faction</h4>
                        {{ form_errors(form.faction) }}
                        <div class="factions-grid">
                            {% for faction_field in form.faction %}
                                <div class="faction-card">
                                    <label class="faction-label">
                                        {{ form_widget(faction_field) }}
                                        <div class="faction-content">
                                            <h4 class="faction-name">{{ faction_field.vars.label }}</h4>
                                            <p class="faction-description">{{ faction_field.vars.attr['data-description'] }}</p>
                                        </div>
                                    </label>
                                </div>
                            {% endfor %}
                        </div>
                    </div>

                    <div>
                        <button class="btn btn-lg btn-primary" type="submit" id="submit-btn" style="display:none;">
                            Rejoindre
                        </button>
                    </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}