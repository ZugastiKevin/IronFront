{% extends 'base.html.twig' %}

{% block title %}{{ site_name }}{% endblock %}

{% block body %}
    <section id="home">
        <div class="home container">
            <h1>{{ site_name }}</h1>

            <div class="player-features">
                <h2>Fonctionnalités du jeu</h2>

                <div class="feature-section">
                    <h3>🎮 Actions du joueur (Frontend)</h3>
                    <ul>
                        <li>Construire et améliorer des bâtiments (cliquez pour confirmer), (exploiter un gisement de ressources, base)</li>
                        <li>Choisir sa faction au début de la partie et la partie</li>
                        <li>Consulter son inventaire de ressources (dans la barre de navigation sous forme d'icônes / montant de la ressource)</li>
                        <li>Suivre les livraisons en cours (visuelles du camion), (voir les détails pour les livraisons sur les batiment de production, exemple: mine de fer)</li>
                        <li>Recevoir des notifications (HTMX en temps réel)</li>
                    </ul>
                </div>

                <div class="feature-section">
                    <h3>⚙️ Système automatique (Backend)</h3>
                    <ul>
                        <li>✓ Vérification des ressources disponibles avant construction</li>
                        <li>✓ Consommation automatique des ressources à la construction</li>
                        <li>✓ Production continue des ressources par les bâtiments</li>
                        <li>✓ Livraison automatique des ressources entre bâtiments</li>
                        <li>✓ Expansion du monde (nouveaux chunks/routes générés)</li>
                        <li>✓ Calcul des coûts exponentiels pour les améliorations</li>
                    </ul>
                </div>

                <div class="feature-section">
                    <h3>🏗️ Architecture du jeu</h3>
                    <ul>
                        <li>Système de chunks géographiques (carte divisée en zones)</li>
                        <li>Routes générées automatiquement pour les livraisons</li>
                        <li>17 entités : User, Player, Game, Building, Faction, Resource...</li>
                        <li>20+ services métiers (BuildingService, RoadService, etc.)</li>
                    </ul>
                </div>
            </div>

            <div id="notifications"
                hx-get="/notifications"
                hx-trigger="load, every 3s"
                hx-swap="innerHTML">
            </div>

            <a href="{{ path('game') }}">Game</a>
        </div>
    </section>
{% endblock %}