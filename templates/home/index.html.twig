{% extends 'base.html.twig' %}

{% block title %}{{ site_name }}{% endblock %}

{% block body %}
    <section id="home">
        <div class="home container">
            <h1>{{ site_name }}</h1>

            <div class="task-table-container">
                <table class="task-table">
                    <thead>
                        <tr>
                            <th>Tâche</th>
                            <th>Description</th>
                            <th>Statut</th>
                            <th>Priorité</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Créer les templates Twig</td>
                            <td>Développer les vues pour la page d'accueil et les formulaires</td>
                            <td><span class="status status-completed">Terminé</span></td>
                            <td><span class="priority priority-medium">Moyenne</span></td>
                        </tr>
                        <tr>
                            <td>Configurer la base de données</td>
                            <td>user / game / faction / building and sub / resource and sub / chunk / road / delivery</td>
                            <td><span class="status status-completed">Terminé</span></td>
                            <td><span class="priority priority-medium">Moyenne</span></td>
                        </tr>
                        <tr>
                            <td>Mettre en place les tests</td>
                            <td>Créer une suite de tests unitaires et fonctionnels</td>
                            <td><span class="status status-completed">Terminé</span></td>
                            <td><span class="priority priority-low">Faible</span></td>
                        </tr>
                        <tr>
                            <td>Configurer le projet Symfony</td>
                            <td>Mettre en place les bundles et les configurations de base</td>
                            <td><span class="status status-completed">Terminé</span></td>
                            <td><span class="priority priority-high">Élevée</span></td>
                        </tr>
                        <tr>
                            <td>Intégrer HTMX</td>
                            <td>Ajouter les interactions dynamiques sans JavaScript</td>
                            <td><span class="status status-completed">Terminé</span></td>
                            <td><span class="priority priority-high">Élevée</span></td>
                        </tr>
                        <tr>
                            <td>Développer les CRUD controllers</td>
                            <td>ResourceImage, Faction, ResourceType, Building, BuildingType, Game, PlayerInventory</td>
                            <td><span class="status status-completed">Terminé</span></td>
                            <td><span class="priority priority-high">Élevée</span></td>
                        </tr>
                        <tr>
                            <td>Implémenter les commandes de monde</td>
                            <td>WorldExpansionCommand, production processing, chunk generation</td>
                            <td><span class="status status-completed">Terminé</span></td>
                            <td><span class="priority priority-medium">Moyenne</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div id="notifications"
                hx-get="/notifications"
                hx-trigger="load, every 3s"
                hx-swap="innerHTML">
            </div>

            <a href="{{ path('game') }}">Game</a>
        </div>
    </section>
{% endblock %}